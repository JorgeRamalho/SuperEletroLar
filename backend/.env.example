PORT=4000
JWT_SECRET=super-eletrolar-dev-secret-change-in-production
FRONTEND_URL=http://localhost:3000

# Banco de dados
# Local (padrão): SQLite em backend/data/trampolim.db — sem configuração extra
# Produção Render/Neon: use uma destas (prioridade DATABASE_URL):
# DATABASE_URL=postgresql://USER:PASSWORD@ep-XXXX.REGION.aws.neon.tech/neondb?sslmode=require
# NEON_DATABASE_URL=postgresql://USER:PASSWORD@ep-XXXX.REGION.aws.neon.tech/neondb?sslmode=require
# POSTGRES_URL=postgresql://USER:PASSWORD@host:5432/trampolim?sslmode=require

# Render
# RENDER_EXTERNAL_URL=https://trampolim.onrender.com
# RENDER=true

# Mercado Pago — https://www.mercadopago.com.br/developers
MERCADOPAGO_ACCESS_TOKEN=TEST-your-access-token-here
MERCADOPAGO_PUBLIC_KEY=TEST-your-public-key-here
# MERCADOPAGO_WEBHOOK_URL=https://trampolim.onrender.com/api/payments/webhook

# Stripe (test)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLIC_KEY=pk_test_your_key_here
