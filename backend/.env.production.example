# ============================================================
# Trampolim — Variáveis de produção (Render + Neon)
# ============================================================
# NÃO commite este arquivo com segredos reais.
# No Render: Environment ? Add Environment Variable
# No Neon: Dashboard ? Connection Details ? Connection string
# ============================================================

NODE_ENV=production
PORT=4000
RENDER=true

# Gerado automaticamente no Render (ou defina um valor forte)
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio

# ------------------------------------------------------------
# BANCO DE DADOS
# ------------------------------------------------------------
# Opção A — PostgreSQL do Render (Blueprint já conecta sozinho)
# DATABASE_URL vem de fromDatabase no render.yaml

# Opção B — Neon (recomendado para Postgres serverless)
# 1. Crie um projeto em https://console.neon.tech
# 2. Copie a connection string (com ?sslmode=require)
# 3. No Render ? Environment ? edite DATABASE_URL com o valor abaixo:
# DATABASE_URL=postgresql://USER:PASSWORD@ep-XXXX.REGION.aws.neon.tech/neondb?sslmode=require

# ------------------------------------------------------------
# URLs DO SITE
# ------------------------------------------------------------
# No Render, RENDER_EXTERNAL_URL é injetado automaticamente.
# FRONTEND_URL deve apontar para a URL pública do app:
# FRONTEND_URL=https://trampolim.onrender.com

# ------------------------------------------------------------
# MERCADO PAGO
# ------------------------------------------------------------
# Sandbox (teste):
# MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxxxxx
# MERCADOPAGO_PUBLIC_KEY=TEST-xxxxxxxx
# Produção:
# MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxx
# MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxxxxxx
# Webhook (use a URL real do Render):
# MERCADOPAGO_WEBHOOK_URL=https://trampolim.onrender.com/api/payments/webhook
